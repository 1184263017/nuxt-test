{
  "name": "nuxt-test",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate": "nuxt generate",
    "postinstall": "nuxt prepare",
    "lint": "pnpm lint:eslint && pnpm lint:style && pnpm format:check",
    "lint:eslint": "eslint .",
    "lint:style": "stylelint \"app/**/*.{vue,scss,css}\"",
    "preview": "nuxt preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@nuxt/content": "3.15.0",
    "@nuxt/image": "2.0.0",
    "@nuxt/scripts": "1.3.1",
    "@nuxtjs/robots": "6.1.2",
    "@nuxtjs/sitemap": "8.2.2",
    "@pinia/nuxt": "0.11.3",
    "@primeuix/themes": "2.0.3",
    "@primevue/nuxt-module": "4.5.5",
    "@sentry/nuxt": "10.65.0",
    "nuxt": "4.4.8",
    "nuxt-schema-org": "6.2.3",
    "pinia": "3.0.4",
    "primeicons": "7.0.0",
    "primevue": "4.5.5",
    "vue": "3.5.39",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@nuxt/eslint": "1.16.0",
    "@playwright/test": "1.61.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "postcss-html": "1.8.1",
    "prettier": "3.9.5",
    "sass": "1.101.0",
    "stylelint": "17.14.0",
    "stylelint-config-recommended-vue": "1.6.1",
    "stylelint-config-standard-scss": "17.0.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10",
    "vue-tsc": "3.3.7"
  },
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": "22.23.1",
    "pnpm": "10.13.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "esbuild",
      "sharp",
      "@sentry/cli",
      "unrs-resolver"
    ]
  }
}
