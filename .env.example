NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_PUBLIC_API_BASE=/api
NUXT_PUBLIC_APP_ENV=development

# Monitoring: keep blank locally. Set these in the deployment platform.
NUXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Web analytics: Google Analytics is loaded only when this value is set.
NUXT_PUBLIC_GOOGLE_ANALYTICS_ID=
